        AnchorPoint = Vector2.new(1, 0.5),
        ThemeTag = { TextColor3 = "SubText" }
    })
    
    local rail = CreateInstance("Frame", {
        Size = UDim2.new(1, 0, 0, 6),
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -10, 0.5, 0),
        BackgroundTransparency = 0.4,
        Parent = element.Frame,
        ThemeTag = { BackgroundColor3 = "SliderRail" }
    }, {
        CreateInstance("UICorner", { CornerRadius = UDim.new(1, 0) }),
        CreateInstance("UISizeConstraint", { MaxSize = Vector2.new(150, math.huge) }),
        valueLabel,
        fill,
        track
    })
    
    local isDragging = false
    
    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
        end
    end)
    
    knob.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local percentage = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            slider:SetValue(slider.Min + ((slider.Max - slider.Min) * percentage))
        end
    end)
    
    slider:SetValue(config.Default)
    library.Options[elementId] = slider
    
    return slider
}

UIElements.Dropdown = {
    Type = "Dropdown",
    __index = {},
    __type = "Dropdown"
}

function UIElements.Dropdown:New(elementId, config)
    local library = self.Library
    assert(config.Title, "Dropdown - Missing Title")
    
    local dropdown = {
        Values = config.Values or {},
        Value = config.Default,
        Multi = config.Multi or false,
        Opened = false,
        Type = "Dropdown",
        Callback = config.Callback or function() end,
        Changed = nil,
        Buttons = {}
    }
    
    local element = CreateElement(config.Title, config.Description, self.Container, false)
    element.DescLabel.Size = UDim2.new(1, -170, 0, 14)
    
    function dropdown:SetTitle(newTitle)
        element:SetTitle(newTitle)
    end
    
    function dropdown:SetDescription(newDescription)
        element:SetDescription(newDescription)
    end
    
    function dropdown:OnChanged(callback)
        dropdown.Changed = callback
        callback(dropdown.Value)
    end
    
    function dropdown:SetValues(newValues)
        dropdown.Values = newValues
        dropdown:BuildDropdownList()
    end
    
    function dropdown:SetValue(newValue)
        if dropdown.Multi then
            local newTable = {}
            for _, value in ipairs(newValue) do
                if table.find(dropdown.Values, value) then
                    newTable[value] = true
                end
            end
            dropdown.Value = newTable
        else
            if not newValue then
                dropdown.Value = nil
            elseif table.find(dropdown.Values, newValue) then
                dropdown.Value = newValue
            end
        end
        dropdown:BuildDropdownList()
        library:SafeCallback(dropdown.Callback, dropdown.Value)
        library:SafeCallback(dropdown.Changed, dropdown.Value)
    end
    
    function dropdown:GetActiveValues()
        if dropdown.Multi then
            local active = {}
            for value, isActive in pairs(dropdown.Value) do
                if isActive then
                    table.insert(active, value)
                end
            end
            return active
        else
            return dropdown.Value
        end
    end
    
    function dropdown:Display()
        local displayText = ""
        if dropdown.Multi then
            local activeValues = {}
            for value, isActive in pairs(dropdown.Value) do
                if isActive then
                    table.insert(activeValues, value)
                end
            end
            displayText = table.concat(activeValues, ", ")
        else
            displayText = dropdown.Value or ""
        end
        valueLabel.Text = (displayText == "" and "--" or displayText)
    end
    
    function dropdown:BuildDropdownList()
        local values = dropdown.Values
        
        for _, child in ipairs(scrollFrame:GetChildren()) do
            if not child:IsA("UIListLayout") then
                child:Destroy()
            end
        end
        
        dropdown.Buttons = {}
        local maxWidth = 0
        
        for _, value in ipairs(values) do
            local isSelected = false
            if dropdown.Multi then
                isSelected = dropdown.Value[value] == true
            else
                isSelected = dropdown.Value == value
            end
            
            local indicator = CreateInstance("Frame", {
                Size = UDim2.fromOffset(4, 14),
                BackgroundColor3 = Color3.fromRGB(76, 194, 255),
                Position = UDim2.fromOffset(-1, 16),
                AnchorPoint = Vector2.new(0, 0.5),
                ThemeTag = { BackgroundColor3 = "Accent" }
            }, { CreateInstance("UICorner", { CornerRadius = UDim.new(0, 2) }) })
            
            local valueText = CreateInstance("TextLabel", {
                FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json"),
                Text = value,
                TextColor3 = Color3.fromRGB(200, 200, 200),
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,
                Size = UDim2.fromScale(1, 1),
                Position = UDim2.fromOffset(10, 0),
                Name = "ButtonLabel",
                ThemeTag = { TextColor3 = "Text" }
            })
            
            local optionButton = CreateInstance("TextButton", {
                Size = UDim2.new(1, -5, 0, 32),
                BackgroundTransparency = 1,
                ZIndex = 23,
                Text = "",
                Parent = scrollFrame,
                ThemeTag = { BackgroundColor3 = "DropdownOption" }
            }, { indicator, valueText, CreateInstance("UICorner", { CornerRadius = UDim.new(0, 6) }) })
            
            if isSelected then
                optionButton.BackgroundTransparency = 0.89
                indicator.BackgroundTransparency = 0
                indicator.Size = UDim2.fromOffset(4, 14)
            else
                optionButton.BackgroundTransparency = 1
                indicator.BackgroundTransparency = 1
                indicator.Size = UDim2.fromOffset(4, 6)
            end
            
            optionButton.MouseEnter:Connect(function()
                if isSelected then
                    optionButton.BackgroundTransparency = 0.85
                else
                    optionButton.BackgroundTransparency = 0.89
                end
            end)
            
            optionButton.MouseLeave:Connect(function()
                if isSelected then
                    optionButton.BackgroundTransparency = 0.89
                else
                    optionButton.BackgroundTransparency = 1
                end
            end)
            
            optionButton.MouseButton1Click:Connect(function()
                if dropdown.Multi then
                    local newState = not isSelected
                    dropdown.Value[value] = newState and true or nil
                    dropdown:BuildDropdownList()
                else
                    if isSelected and not config.AllowNull then
                        return
                    end
                    dropdown.Value = (isSelected and nil or value)
                    dropdown:BuildDropdownList()
                end
                dropdown:Display()
                library:SafeCallback(dropdown.Callback, dropdown.Value)
                library:SafeCallback(dropdown.Changed, dropdown.Value)
            end)
            
            local textWidth = valueText.TextBounds.X
            if textWidth > maxWidth then
                maxWidth = textWidth
            end
            
            dropdown.Buttons[optionButton] = true
        end
        
        local dropdownWidth = math.max(maxWidth + 30, 170)
        popupFrame.Size = UDim2.fromOffset(dropdownWidth, 300)
        dropdownFrame.Size = UDim2.fromOffset(dropdownWidth, 30)
        
        task.defer(function()
            listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Wait()
            scrollFrame.CanvasSize = UDim2.fromOffset(0, listLayout.AbsoluteContentSize.Y)
        end)
    end
    
    function dropdown:Open()
        if dropdown.Opened then
            return
        end
        dropdown.Opened = true
        self.ScrollFrame.ScrollingEnabled = false
        
        local buttonPos = dropdownFrame.AbsolutePosition
        local popupX = buttonPos.X
        local popupY = buttonPos.Y + dropdownFrame.AbsoluteSize.Y + 4
        
        if popupY + popupFrame.AbsoluteSize.Y > Camera.ViewportSize.Y - 8 then
            popupY = buttonPos.Y - popupFrame.AbsoluteSize.Y - 4
        end
        popupY = math.max(8, popupY)
        
        popupFrame.Position = UDim2.fromOffset(popupX, popupY)
        popupFrame.Visible = true
        
        TweenService:Create(contentFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { Size = UDim2.fromScale(1, 1) }):Play()
    end
    
    function dropdown:Close()
        if not dropdown.Opened then
            return
        end
        dropdown.Opened = false
        self.ScrollFrame.ScrollingEnabled = true
        contentFrame.Size = UDim2.fromScale(1, 0.6)
        popupFrame.Visible = false
    end
    
    function dropdown:Destroy()
        element:Destroy()
        popupFrame:Destroy()
        library.Options[elementId] = nil
    end
    
    local valueLabel = CreateInstance("TextLabel", {
        FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Regular, Enum.FontStyle.Normal),
        Text = "Value",
        TextColor3 = Color3.fromRGB(240, 240, 240),
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Size = UDim2.new(1, -30, 0, 14),
        Position = UDim2.new(0, 8, 0.5, 0),
        AnchorPoint = Vector2.new(0, 0.5),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 1,
        TextTruncate = Enum.TextTruncate.AtEnd,
        ThemeTag = { TextColor3 = "Text" }
    })
    
    local arrowIcon = CreateInstance("ImageLabel", {
        Image = "rbxassetid://10709790948",
        Size = UDim2.fromOffset(16, 16),
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -8, 0.5, 0),
        BackgroundTransparency = 1,
        ThemeTag = { ImageColor3 = "SubText" }
    })
    
    local dropdownFrame = CreateInstance("TextButton", {
        Size = UDim2.fromOffset(160, 30),
        Position = UDim2.new(1, -10, 0.5, 0),
        AnchorPoint = Vector2.new(1, 0.5),
        BackgroundTransparency = 0.9,
        Parent = element.Frame,
        ThemeTag = { BackgroundColor3 = "DropdownFrame" }
    }, {
        CreateInstance("UICorner", { CornerRadius = UDim.new(0, 5) }),
        CreateInstance("UIStroke", { Transparency = 0.5, ApplyStrokeMode = Enum.ApplyStrokeMode.Border, ThemeTag = { Color = "InElementBorder" } }),
        arrowIcon,
        valueLabel
    })
    
    local listLayout = CreateInstance("UIListLayout", { Padding = UDim.new(0, 3) })
    
    local scrollFrame = CreateInstance("ScrollingFrame", {
        Size = UDim2.new(1, -5, 1, -10),
        Position = UDim2.fromOffset(5, 5),
        BackgroundTransparency = 1,
        BottomImage = "rbxassetid://6889812791",
        MidImage = "rbxassetid://6889812721",
        TopImage = "rbxassetid://6276641225",
        ScrollBarImageColor3 = Color3.fromRGB(255, 255, 255),
        ScrollBarImageTransparency = 0.95,
        ScrollBarThickness = 4,
        BorderSizePixel = 0,
        CanvasSize = UDim2.fromScale(0, 0)
    }, { listLayout })
    
    local contentFrame = CreateInstance("Frame", {
        Size = UDim2.fromScale(1, 0.6),
        ThemeTag = { BackgroundColor3 = "DropdownHolder" }
    }, {
        scrollFrame,
        CreateInstance("UICorner", { CornerRadius = UDim.new(0, 7) }),
        CreateInstance("UIStroke", { ApplyStrokeMode = Enum.ApplyStrokeMode.Border, ThemeTag = { Color = "DropdownBorder" } })
    })
    
    local popupFrame = CreateInstance("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.fromOffset(170, 300),
        Parent = library.PopupGUI,
        Visible = false
    }, { contentFrame, CreateInstance("UISizeConstraint", { MinSize = Vector2.new(170, 0) }) })
    
    table.insert(library.OpenFrames, popupFrame)
    
    dropdownFrame.MouseButton1Click:Connect(function()
        if dropdown.Opened then
            dropdown:Close()
        else
            dropdown:Open()
        end
    end)
    
    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if dropdown.Opened then
                local pos = contentFrame.AbsolutePosition
                local size = contentFrame.AbsoluteSize
                if Mouse.X < pos.X or Mouse.X > pos.X + size.X or Mouse.Y < pos.Y - 20 or Mouse.Y > pos.Y + size.Y then
                    dropdown:Close()
                end
            end
        end
    end)
    
    dropdownFrame:GetPropertyChangedSignal("AbsolutePosition"):Connect(function()
        if dropdown.Opened then
            local buttonPos = dropdownFrame.AbsolutePosition
            local popupX = buttonPos.X
            local popupY = buttonPos.Y + dropdownFrame.AbsoluteSize.Y + 4
            if popupY + popupFrame.AbsoluteSize.Y > Camera.ViewportSize.Y - 8 then
                popupY = buttonPos.Y - popupFrame.AbsoluteSize.Y - 4
            end
            popupY = math.max(8, popupY)
            popupFrame.Position = UDim2.fromOffset(popupX, popupY)
        end
    end)
    
    dropdown:BuildDropdownList()
    dropdown:Display()
    
    if config.Default then
        if type(config.Default) == "string" then
            if table.find(dropdown.Values, config.Default) then
                if dropdown.Multi then
                    dropdown.Value[config.Default] = true
                else
                    dropdown.Value = config.Default
                end
            end
        elseif type(config.Default) == "table" then
            for _, value in ipairs(config.Default) do
                if table.find(dropdown.Values, value) then
                    dropdown.Value[value] = true
                end
            end
        end
        dropdown:BuildDropdownList()
        dropdown:Display()
