    Folder = "BetterFluentCache"
}

function FluentPro.MediaManager:SetFolder(folderName)
    self.Folder = folderName
end

local function EnsureFolder(path)
    pcall(function()
        if not isfolder(path) then
            makefolder(path)
        end
    end)
end

local function GenerateRandomFileName(extension)
    local chars = "abcdefghijklmnopqrstuvwxyz0123456789"
    local name = ""
    for _ = 1, 12 do
        local index = math.random(1, #chars)
        name = name .. chars:sub(index, index)
    end
    return name .. "." .. extension
end

local function FetchMedia(url, subFolder, allowedExtensions, defaultExtension)
    if type(url) ~= "string" or url == "" then
        return ""
    end
    
    if url:match("^rbxassetid://") or url:match("^rbxasset://") then
        return url
    end
    
    if url:match("^%d+$") then
        return "rbxassetid://" .. url
    end
    
    if not url:match("^https?://") then
        return ""
    end
    
    local cleanPath = url:match("^[^?#]+") or url
    local extension = (cleanPath:match("%.([^%.%/]+)$") or defaultExtension):lower()
    
    if not allowedExtensions[extension] then
        extension = defaultExtension
    end
    
    local mapPath = "bfc_" .. subFolder .. "_map.json"
    local fileMap = {}
    
    pcall(function()
        if isfile(mapPath) then
            local success, data = pcall(HttpService.JSONDecode, HttpService, readfile(mapPath))
            if success and type(data) == "table" then
                fileMap = data
            end
        end
    end)
    
    local cacheKey = tostring(#url) .. "_" .. url:sub(1, 40):gsub("[^%w]", "")
    
    if fileMap[cacheKey] then
        local cachedPath = fileMap[cacheKey]
        if isfile(cachedPath) then
            local success, assetPath = pcall(getcustomasset, cachedPath)
            if success and assetPath and assetPath ~= "" then
                return assetPath
            end
        end
        fileMap[cacheKey] = nil
    end
    
    local responseBody = nil
    local downloadSuccess = pcall(function()
        local requestFunction = (syn and syn.request) or http_request or request
        local response = requestFunction({
            Url = url,
            Method = "GET",
            Headers = { ["User-Agent"] = "Roblox/WinInet" }
        })
        if response and response.Body and #response.Body > 128 then
            responseBody = response.Body
        end
    end)
    
    if not (downloadSuccess and responseBody) then
        return ""
    end
    
    local isFtyp = #responseBody >= 8 and responseBody:sub(5, 8) == "ftyp"
    local fileName = GenerateRandomFileName(isFtyp and "ogg" or extension)
    
    writefile(fileName, responseBody)
    
    if isfile(fileName) then
        local success, assetPath = pcall(getcustomasset, fileName)
        if success and assetPath and assetPath ~= "" then
            fileMap[cacheKey] = fileName
            pcall(function()
                local success, encoded = pcall(HttpService.JSONEncode, HttpService, fileMap)
                if success then
                    writefile(mapPath, encoded)
                end
            end)
            return assetPath
        end
    end
    
    return ""
end

function FluentPro.MediaManager:Image(url)
    return FetchMedia(url, "images", { png = 1, jpg = 1, jpeg = 1, webp = 1, gif = 1 }, "png")
end

function FluentPro.MediaManager:Audio(url)
    return FetchMedia(url, "audio", { mp3 = 1, ogg = 1, wav = 1, flac = 1 }, "mp3")
end

function FluentPro.MediaManager:Video(url)
    if type(url) ~= "string" or url == "" then
        return ""
    end
    
    if url:match("^rbxassetid://") or url:match("^rbxasset://") then
        return url
    end
    
    if url:match("^%d+$") then
        return "rbxassetid://" .. url
    end
    
    if not url:match("^https?://") then
        return ""
    end
    
    local extension = (url:match("%.(%a+)%??[^/]*$") or "webm"):lower()
    if not ({ webm = 1, mp4 = 1, ogg = 1, mov = 1 })[extension] then
        extension = "webm"
    end
    if extension == "mp4" or extension == "mov" then
        extension = "webm"
    end
    
    EnsureFolder(self.Folder .. "/videos")
    
    local videoDir = self.Folder .. "/videos"
    local mapPath = videoDir .. "/_map.json"
    local fileMap = {}
    
    pcall(function()
        if isfile(mapPath) then
            local success, data = pcall(HttpService.JSONDecode, HttpService, readfile(mapPath))
            if success and type(data) == "table" then
                fileMap = data
            end
        end
    end)
    
    local cacheKey = tostring(#url) .. "_" .. url:sub(1, 40):gsub("[^%w]", "")
    
    if fileMap[cacheKey] then
        local cachedPath = videoDir .. "/" .. fileMap[cacheKey]
        if isfile(cachedPath) then
            local success, assetPath = pcall(getcustomasset, cachedPath)
            if success and assetPath and assetPath ~= "" then
                return assetPath
            end
        end
        fileMap[cacheKey] = nil
    end
    
    local fileName = GenerateRandomFileName(extension)
    local fullPath = videoDir .. "/" .. fileName
    local responseBody = nil
    
    local requestSuccess = pcall(function()
        local requestFunction = (syn and syn.request) or http_request or request
        local response = requestFunction({
            Url = url,
            Method = "GET",
            Headers = { ["User-Agent"] = "Roblox/WinInet" }
        })
        if response and response.Body and #response.Body > 512 then
            local peek = response.Body:sub(1, 15):lower()
            if peek:find("<!doctype") or peek:find("<html") then
                return
            end
            responseBody = response.Body
            writefile(fullPath, responseBody)
        end
    end)
    
    if requestSuccess and responseBody and isfile(fullPath) then
        local success, assetPath = pcall(getcustomasset, fullPath)
        if success and assetPath and assetPath ~= "" then
            fileMap[cacheKey] = fileName
            pcall(function()
                local success, encoded = pcall(HttpService.JSONEncode, HttpService, fileMap)
                if success then
                    writefile(mapPath, encoded)
                end
            end)
            return assetPath
        end
    end
    
    return ""
end

FluentPro.Acrylic = {
    BlurEffect = nil,
    ExistingEffects = {},
    Enabled = false
}

function FluentPro.Acrylic:Init()
    if self.BlurEffect then
        return
    end
    
    self.BlurEffect = Instance.new("DepthOfFieldEffect")
    self.BlurEffect.FarIntensity = 0
    self.BlurEffect.InFocusRadius = 0.1
    self.BlurEffect.NearIntensity = 1
    self.ExistingEffects = {}
    
    local function CaptureEffect(effect)
        if effect:IsA("DepthOfFieldEffect") then
            self.ExistingEffects[effect] = { enabled = effect.Enabled }
        end
    end
    
    for _, effect in pairs(Lighting:GetChildren()) do
        CaptureEffect(effect)
    end
    
    if Workspace.CurrentCamera then
        for _, effect in pairs(Workspace.CurrentCamera:GetChildren()) do
            CaptureEffect(effect)
        end
    end
    
    self:Enable()
end

function FluentPro.Acrylic:Enable()
    if not self.BlurEffect then
        self:Init()
        return
    end
    
    for effect, data in pairs(self.ExistingEffects) do
        effect.Enabled = false
    end
    
    self.BlurEffect.Parent = Lighting
    self.Enabled = true
end

function FluentPro.Acrylic:Disable()
    if not self.BlurEffect then
        return
    end
    
    for effect, data in pairs(self.ExistingEffects) do
        effect.Enabled = data.enabled
    end
    
    self.BlurEffect.Parent = nil
    self.Enabled = false
end

function FluentPro.Acrylic:CreatePaint()
    return CreateAcrylicPaint()
end

