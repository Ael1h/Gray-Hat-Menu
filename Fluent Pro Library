    function tab:AddSection(sectionTitle)
        local section = { Type = "Section" }
        local sectionContainer = CreateInstance("Frame", {
            Size = UDim2.new(1, 0, 0, 26),
            Position = UDim2.fromOffset(0, 24),
            BackgroundTransparency = 1,
            Parent = containerFrame,
            LayoutOrder = 7
        }, {
            CreateInstance("TextLabel", {
                RichText = true,
                Text = sectionTitle,
                TextTransparency = 0,
                FontFace = Font.new("rbxassetid://12187365364", Enum.FontWeight.SemiBold, Enum.FontStyle.Normal),
                TextSize = 18,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextYAlignment = Enum.TextYAlignment.Center,
                Size = UDim2.new(1, -16, 0, 18),
                Position = UDim2.fromOffset(0, 2),
                ThemeTag = { TextColor3 = "Text" }
            })
        })
        
        local elementContainer = CreateInstance("Frame", {
            Size = UDim2.new(1, 0, 0, 26),
            BackgroundTransparency = 1
        }, { CreateInstance("UIListLayout", { Padding = UDim.new(0, 5), SortOrder = Enum.SortOrder.LayoutOrder }) })
        elementContainer.Parent = sectionContainer
        
        local layout = elementContainer:FindFirstChildOfClass("UIListLayout")
        layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            elementContainer.Size = UDim2.new(1, 0, 0, layout.AbsoluteContentSize.Y)
            sectionContainer.Size = UDim2.new(1, 0, 0, layout.AbsoluteContentSize.Y + 25)
        end)
        
        section.Container = elementContainer
        section.ScrollFrame = containerFrame
        section._elementCount = 0
        
        local elementsMetatable = {}
        elementsMetatable.__index = elementsMetatable
        
        for elementName, elementModule in pairs(UIElements) do
            elementsMetatable["Add" .. elementModule.Type] = function(self, elementId, elementConfig)
                elementModule.Container = self.Container
                elementModule.Type = self.Type
                elementModule.ScrollFrame = self.ScrollFrame
                elementModule.Library = FluentPro
                
                local result = elementModule:New(elementId, elementConfig)
                
                if result and result.Frame then
                    self._elementCount = (self._elementCount or 0) + 1
                    result.Frame.LayoutOrder = self._elementCount
                end
                
                if result and elementConfig and elementConfig.Icon then
                    local iconData = FluentPro:GetIcon(elementConfig.Icon)
                    if iconData and result.Frame then
                        local iconImage = CreateInstance("ImageLabel", {
                            BackgroundTransparency = 1,
                            Size = UDim2.fromOffset(15, 15),
                            Position = UDim2.new(0, -3, 0.5, 0),
                            AnchorPoint = Vector2.new(1, 0.5),
                            ZIndex = 2
                        })
                        if type(iconData) == "table" then
                            iconImage.Image = iconData.Image or ""
                            iconImage.ImageRectOffset = iconData.ImageRectOffset or Vector2.new(0, 0)
                            iconImage.ImageRectSize = iconData.ImageRectSize or Vector2.new(0, 0)
                        else
                            iconImage.Image = tostring(iconData)
                        end
                        iconImage.Parent = result.Frame
                        if result.LabelHolder then
                            result.LabelHolder.Position = UDim2.fromOffset(26, 0)
                        end
                    end
                end
                
                local window = FluentPro.Window
                if window and window.AllElements and result then
                    local elementFrame = result.Frame or result
                    local elementTitle = (type(elementId) == "string" and elementId) or (type(elementConfig) == "table" and (elementConfig.Title or "")) or ""
                    if elementFrame and elementTitle ~= "" then
                        window.AllElements[elementFrame] = string.lower(elementTitle)
                    end
                end
                
                return result
            end
        end
        
        setmetatable(section, elementsMetatable)
        
        return section
    end
    
    return tab
end

function Tabs:SelectTab(tabIndex)
    local window = self.Window
    
    self.SelectedTab = tabIndex
    
    for index, tab in pairs(self.Tabs) do
        tab.Frame.BackgroundTransparency = 1
        tab.Selected = false
    end
    
    self.Tabs[tabIndex].Frame.BackgroundTransparency = 0.89
    self.Tabs[tabIndex].Selected = true
    
    window.TabDisplay.Text = self.Tabs[tabIndex].Name
    
    task.spawn(function()
        for index, container in pairs(self.Containers) do
            container.Visible = false
        end
        self.Containers[tabIndex].Visible = true
    end)
end

