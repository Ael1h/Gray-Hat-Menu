    }
    
    local element = CreateElement(config.Title, config.Description, self.Container, false)
    element.DescLabel.Size = UDim2.new(1, -170, 0, 14)
    
    function slider:SetTitle(newTitle)
        element:SetTitle(newTitle)
    end
    
    function slider:SetDescription(newDescription)
        element:SetDescription(newDescription)
    end
    
    function slider:OnChanged(callback)
        slider.Changed = callback
        callback(slider.Value)
