}

function FluentPro:SafeCallback(callback, ...)
    if not callback then
        return
    end
    
    local success, errorMessage = pcall(callback, ...)
    
    if not success then
        local message = tostring(errorMessage)
        local line = message:match(":(%d+):") or message:match("[Ll]ine%s+(%d+)")
        local hint = nil
        
        local lowerMessage = message:lower()
        for _, pair in ipairs(errorHints) do
            if lowerMessage:find(pair[1], 1, true) then
                hint = pair[2]
                break
            end
        end
        
        local smartMessage = message
        if hint and line then
            smartMessage = hint .. " (Line " .. line .. ")"
        elseif hint then
            smartMessage = hint
        elseif line then
            smartMessage = "Check your code (Line " .. line .. ")"
        end
        
        self:Notify({
            Title = "Callback Error",
            Content = smartMessage,
            SubContent = message,
            Type = "Error",
            Duration = 5
        })
    end
end

local rgbConnection = nil

function FluentPro:StartRGBMode()
    if rgbConnection then
        rgbConnection:Disconnect()
        rgbConnection = nil
    end
    
    local hue = 0
    rgbConnection = RunService.RenderStepped:Connect(function(deltaTime)
        if self.CurrentTheme ~= "RGB" then
            if rgbConnection then
                rgbConnection:Disconnect()
                rgbConnection = nil
            end
            return
        end
        
        hue = (hue + deltaTime * 0.10) % 1
        local color = Color3.fromHSV(hue, 1, 1)
        
        local theme = Themes["RGB"]
        if theme then
            theme.Accent = color
            theme.AcrylicBorder = color
            theme.InElementBorder = color
            theme.DropdownBorder = color
            theme.DropdownFrame = color
            theme.DropdownOption = color
            theme.Tab = color
            theme.TitleBarLine = color
            UpdateTheme()
        end
    end)
end

function FluentPro:StopRGBMode()
    if rgbConnection then
        rgbConnection:Disconnect()
        rgbConnection = nil
    end
end

function FluentPro:RegisterCustomTheme(themeName, themeData)
    if type(themeName) ~= "string" or type(themeData) ~= "table" then
        return false
    end
    
    themeData.Name = themeName
    
    if not themeData.ThemeAccentColors and themeData.Accent then
        themeData.ThemeAccentColors = { themeData.Accent }
    end
    
    if themeData.Background == nil then
        themeData.Background = nil
    end
    
    if themeData.BackgroundTransparency == nil then
        themeData.BackgroundTransparency = 0
    end
    
    Themes[themeName] = themeData
    
    local found = false
    for _, existingName in ipairs(self.Themes) do
        if existingName == themeName then
            found = true
            break
        end
    end
    
    if not found then
        table.insert(self.Themes, themeName)
    end
    
    return true
end

FluentPro.AddCustomTheme = FluentPro.RegisterCustomTheme

