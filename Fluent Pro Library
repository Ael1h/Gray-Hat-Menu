}

function FluentPro.FloatingButtonManager:SetLibrary(library)
    self.Library = library
end

function FluentPro.FloatingButtonManager:SetFolder(folderName)
    self.Folder = folderName
    self:BuildFolderTree()
end

function FluentPro.FloatingButtonManager:BuildFolderTree()
    local paths = { self.Folder, self.Folder .. "/settings" }
    for _, path in ipairs(paths) do
        if not isfolder(path) then
            makefolder(path)
        end
    end
end

function FluentPro.FloatingButtonManager:AddButton(id, buttonOrFrame, isLocked, isCircle, applyShapeCallback, targetFrame)
    local actualFrame = targetFrame or buttonOrFrame
    
    if buttonOrFrame:IsA("TextButton") and not targetFrame then
        local parent = buttonOrFrame.Parent
        if parent and parent:IsA("Frame") then
            actualFrame = parent
        end
    end
    
    self.Buttons[id] = {
        frame = actualFrame,
        button = buttonOrFrame,
        applyShape = applyShapeCallback
    }
    
    actualFrame:SetAttribute("Locked", isLocked or false)
    actualFrame:SetAttribute("IsCircle", isCircle or false)
end

local function SerializeUDim2(udim2)
    return {
        ScaleX = udim2.X.Scale,
        OffsetX = udim2.X.Offset,
        ScaleY = udim2.Y.Scale,
        OffsetY = udim2.Y.Offset
    }
end

local function DeserializeUDim2(data)
    return UDim2.new(data.ScaleX or 0, data.OffsetX or 0, data.ScaleY or 0, data.OffsetY or 0)
end

function FluentPro.FloatingButtonManager:Save(layoutName)
    local filePath = self.Folder .. "/settings/" .. layoutName .. ".json"
    local data = {}
    
    for id, entry in pairs(self.Buttons) do
        local targetFrame = entry.frame or entry
        data[id] = {
            size = SerializeUDim2(targetFrame.Size),
            position = SerializeUDim2(targetFrame.Position),
            locked = targetFrame:GetAttribute("Locked") or false,
            isCircle = targetFrame:GetAttribute("IsCircle") or false
        }
    end
    
    local success, encoded = pcall(HttpService.JSONEncode, HttpService, data)
    if not success then
        return false, "Encode failed"
    end
    
    writefile(filePath, encoded)
    return true
end

function FluentPro.FloatingButtonManager:Load(layoutName)
    local filePath = self.Folder .. "/settings/" .. layoutName .. ".json"
    if not isfile(filePath) then
        return false, "No such file"
    end
    
    local success, decoded = pcall(HttpService.JSONDecode, HttpService, readfile(filePath))
    if not success then
        return false, "Decode failed"
    end
    
    for id, savedData in pairs(decoded) do
        local entry = self.Buttons[id]
        if entry then
            local targetFrame = entry.frame or entry
            if savedData.position then
                targetFrame.Position = DeserializeUDim2(savedData.position)
            end
            if savedData.size then
                targetFrame.Size = DeserializeUDim2(savedData.size)
            end
            targetFrame:SetAttribute("Locked", savedData.locked or false)
            targetFrame:SetAttribute("IsCircle", savedData.isCircle or false)
            
            if entry.applyShape then
                task.defer(function()
                    pcall(entry.applyShape, savedData.isCircle or false)
                end)
            end
        end
    end
    
    return true
end

function FluentPro.FloatingButtonManager:RefreshConfigList()
    local files = listfiles(self.Folder .. "/settings")
    local layouts = {}
    
    for _, filePath in ipairs(files) do
        if filePath:sub(-5) == ".json" then
            local name = filePath:match("([^/\\]+)%.json$")
            if name then
                table.insert(layouts, name)
            end
        end
    end
    
    return layouts
end

function FluentPro.FloatingButtonManager:LoadAutoloadConfig()
    local autoPath = self.Folder .. "/settings/autoload.txt"
    if isfile(autoPath) then
        local layoutName = readfile(autoPath)
        local success, errorMessage = self:Load(layoutName)
        if not success then
            return self.Library:Notify({
                Title = "Floating Buttons",
                Content = "Failed to load autoload layout: " .. tostring(errorMessage),
                Duration = 5
            })
        end
        self.Library:Notify({
            Title = "Floating Buttons",
            Content = string.format('Auto loaded layout "%s"', layoutName),
            Duration = 5
        })
    end
end

