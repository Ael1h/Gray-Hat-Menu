UIElements.Keybind = {
    Type = "Keybind",
    __index = {},
    __type = "Keybind"
}

function UIElements.Keybind:New(elementId, config)
    local library = self.Library
    assert(config.Title, "Keybind - Missing Title")
    assert(config.Default, "Keybind - Missing default value")
    
    local keybind = {
        Value = config.Default,
        Toggled = false,
        Mode = config.Mode or "Toggle",
        Type = "Keybind",
        Callback = config.Callback or function() end,
        ChangedCallback = config.ChangedCallback or function() end,
        Changed = nil,
        Clicked = nil
    }
    
    local element = CreateElement(config.Title, config.Description, self.Container, true)
    
    function keybind:SetTitle(newTitle)
        element:SetTitle(newTitle)
    end
    
    function keybind:SetDescription(newDescription)
        element:SetDescription(newDescription)
    end
    
    function keybind:OnChanged(callback)
        keybind.Changed = callback
        callback(keybind.Value)
    end
    
    function keybind:OnClick(callback)
        keybind.Clicked = callback
    end
    
    function keybind:SetValue(newKey, newMode)
        newKey = newKey or keybind.Value
        newMode = newMode or keybind.Mode
        keyLabel.Text = newKey
        keybind.Value = newKey
        keybind.Mode = newMode
    end
    
    function keybind:GetState()
        if UserInputService:GetFocusedTextBox() and keybind.Mode ~= "Always" then
            return false
        end
        if keybind.Mode == "Always" then
            return true
        elseif keybind.Mode == "Hold" then
            if keybind.Value == "None" then
                return false
            end
            local key = keybind.Value
            if key == "MouseLeft" then
                return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
            elseif key == "MouseRight" then
                return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
            else
                return UserInputService:IsKeyDown(Enum.KeyCode[key])
            end
        else
            return keybind.Toggled
        end
    end
    
    function keybind:DoClick()
        library:SafeCallback(keybind.Callback, keybind.Toggled)
        library:SafeCallback(keybind.Clicked, keybind.Toggled)
    end
    
    function keybind:Destroy()
        element:Destroy()
        library.Options[elementId] = nil
    end
    
    local keyLabel = CreateInstance("TextLabel", {
        FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Regular, Enum.FontStyle.Normal),
        Text = config.Default,
        TextColor3 = Color3.fromRGB(240, 240, 240),
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Center,
        Size = UDim2.new(0, 0, 0, 14),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundTransparency = 1,
        ThemeTag = { TextColor3 = "Text" }
    })
    
    local mouseIcon = CreateInstance("ImageLabel", {
        Size = UDim2.fromOffset(13, 13),
        BackgroundTransparency = 1,
        Image = "rbxassetid://10734898592",
        ImageTransparency = 0.35,
        LayoutOrder = 1,
        ThemeTag = { ImageColor3 = "SubText" }
    })
    
    local keyButton = CreateInstance("TextButton", {
        Size = UDim2.fromOffset(0, 30),
        Position = UDim2.new(1, -10, 0.5, 0),
        AnchorPoint = Vector2.new(1, 0.5),
        BackgroundTransparency = 0.9,
        Parent = element.Frame,
        AutomaticSize = Enum.AutomaticSize.X,
        ThemeTag = { BackgroundColor3 = "Keybind" }
    }, {
        CreateInstance("UICorner", { CornerRadius = UDim.new(0, 5) }),
        CreateInstance("UIPadding", { PaddingLeft = UDim.new(0, 7), PaddingRight = UDim.new(0, 8) }),
        CreateInstance("UIListLayout", {
            FillDirection = Enum.FillDirection.Horizontal,
            VerticalAlignment = Enum.VerticalAlignment.Center,
            Padding = UDim.new(0, 4),
            SortOrder = Enum.SortOrder.LayoutOrder
        }),
        CreateInstance("UIStroke", { Transparency = 0.5, ApplyStrokeMode = Enum.ApplyStrokeMode.Border, ThemeTag = { Color = "InElementBorder" } }),
        mouseIcon,
        keyLabel
    })
    
    local isListening = false
    local listeningConnection = nil
    local endedConnection = nil
    
    keyButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isListening = true
            keyLabel.Text = "..."
            task.wait(0.2)
            
            listeningConnection = UserInputService.InputBegan:Connect(function(input)
                local keyName = nil
                if input.UserInputType == Enum.UserInputType.Keyboard then
                    keyName = input.KeyCode.Name
                elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
                    keyName = "MouseLeft"
                elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
                    keyName = "MouseRight"
                end
                
                endedConnection = UserInputService.InputEnded:Connect(function(input)
                    if input.KeyCode.Name == keyName or
                       (keyName == "MouseLeft" and input.UserInputType == Enum.UserInputType.MouseButton1) or
                       (keyName == "MouseRight" and input.UserInputType == Enum.UserInputType.MouseButton2) then
                        isListening = false
                        keyLabel.Text = keyName
                        keybind.Value = keyName
                        library:SafeCallback(keybind.ChangedCallback, input.KeyCode or input.UserInputType)
                        library:SafeCallback(keybind.Changed, input.KeyCode or input.UserInputType)
                        if listeningConnection then listeningConnection:Disconnect() end
                        if endedConnection then endedConnection:Disconnect() end
                    end
                end)
            end)
        end
    end)
    
    UserInputService.InputBegan:Connect(function(input)
        if not isListening and not UserInputService:GetFocusedTextBox() then
            if keybind.Mode == "Toggle" then
                local key = keybind.Value
                if key == "MouseLeft" and input.UserInputType == Enum.UserInputType.MouseButton1 then
                    keybind.Toggled = not keybind.Toggled
                    keybind:DoClick()
                elseif key == "MouseRight" and input.UserInputType == Enum.UserInputType.MouseButton2 then
                    keybind.Toggled = not keybind.Toggled
                    keybind:DoClick()
                elseif input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode.Name == key then
                    keybind.Toggled = not keybind.Toggled
                    keybind:DoClick()
                end
            elseif keybind.Mode == "Hold" then
                local key = keybind.Value
                if key == "MouseLeft" and input.UserInputType == Enum.UserInputType.MouseButton1 then
                    library:SafeCallback(keybind.Callback, true)
                elseif key == "MouseRight" and input.UserInputType == Enum.UserInputType.MouseButton2 then
                    library:SafeCallback(keybind.Callback, true)
                elseif input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode.Name == key then
                    library:SafeCallback(keybind.Callback, true)
                end
            end
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if not UserInputService:GetFocusedTextBox() then
            if keybind.Mode == "Hold" then
                local key = keybind.Value
                if key == "MouseLeft" and input.UserInputType == Enum.UserInputType.MouseButton1 then
                    library:SafeCallback(keybind.Callback, false)
                elseif key == "MouseRight" and input.UserInputType == Enum.UserInputType.MouseButton2 then
                    library:SafeCallback(keybind.Callback, false)
                elseif input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode.Name == key then
                    library:SafeCallback(keybind.Callback, false)
                end
            end
        end
    end)
    
    library.Options[elementId] = keybind
    
    return keybind
end

UIElements.Input = {
    Type = "Input",
    __index = {},
    __type = "Input"
}

function UIElements.Input:New(elementId, config)
    local library = self.Library
    assert(config.Title, "Input - Missing Title")
    
    local input = {
        Value = config.Default or "",
        Numeric = config.Numeric or false,
        Finished = config.Finished or false,
        Type = "Input",
        Callback = config.Callback or function() end,
        Changed = nil
    }
    
    local element = CreateElement(config.Title, config.Description, self.Container, false)
    
    function input:SetTitle(newTitle)
        element:SetTitle(newTitle)
    end
    
    function input:SetDescription(newDescription)
        element:SetDescription(newDescription)
    end
    
    function input:OnChanged(callback)
        input.Changed = callback
        callback(input.Value)
    end
    
    function input:SetValue(newValue)
        if config.MaxLength and #newValue > config.MaxLength then
            newValue = newValue:sub(1, config.MaxLength)
        end
        if input.Numeric then
            if not tonumber(newValue) and #newValue > 0 then
                newValue = input.Value
            end
        end
        input.Value = newValue
        textBox.Text = newValue
        library:SafeCallback(input.Callback, input.Value)
        library:SafeCallback(input.Changed, input.Value)
    end
    
    function input:Destroy()
        element:Destroy()
        library.Options[elementId] = nil
    end
    
    local textBoxFrame = CreateInstance("Frame", {
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        Position = UDim2.new(0, 6, 0, 0),
        Size = UDim2.new(1, -12, 1, 0)
    })
    
    local textBox = CreateInstance("TextBox", {
        FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json"),
        TextColor3 = Color3.fromRGB(200, 200, 200),
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 1),
        Position = UDim2.fromOffset(10, 0),
        ThemeTag = { TextColor3 = "Text", PlaceholderColor3 = "SubText" }
    })
    textBox.Parent = textBoxFrame
    
    local indicator = CreateInstance("Frame", {
        Size = UDim2.new(1, -4, 0, 1),
        Position = UDim2.new(0, 2, 1, 0),
        AnchorPoint = Vector2.new(0, 1),
        BackgroundTransparency = 0.5,
        ThemeTag = { BackgroundColor3 = "InputIndicator" }
    })
    
    local inputFrame = CreateInstance("Frame", {
        Size = UDim2.new(0, 0, 0, 30),
        BackgroundTransparency = 0.9,
        Parent = element.Frame,
        ThemeTag = { BackgroundColor3 = "Input" }
    }, {
        CreateInstance("UICorner", { CornerRadius = UDim.new(0, 4) }),
        CreateInstance("UIStroke", { ApplyStrokeMode = Enum.ApplyStrokeMode.Border, Transparency = 0.5, ThemeTag = { Color = "InElementBorder" } }),
        indicator,
        textBoxFrame
    })
    
    textBox.PlaceholderText = config.Placeholder or ""
    textBox.Text = config.Default or ""
    
    local function updateCursor()
        local padding = 2
        local containerWidth = textBoxFrame.AbsoluteSize.X
        
        if not textBox:IsFocused() or textBox.TextBounds.X <= containerWidth - 2 * padding then
            textBox.Position = UDim2.new(0, padding, 0, 0)
        else
            local cursorPos = textBox.CursorPosition
            if cursorPos ~= -1 then
                local textBefore = string.sub(textBox.Text, 1, cursorPos - 1)
                local textWidth = TextService:GetTextSize(textBefore, textBox.TextSize, textBox.Font, Vector2.new(math.huge, math.huge)).X
                local currentOffset = textBox.Position.X.Offset
                if currentOffset + textWidth < padding then
                    textBox.Position = UDim2.fromOffset(padding - textWidth, 0)
                elseif currentOffset + textWidth > containerWidth - padding - 1 then
                    textBox.Position = UDim2.fromOffset(containerWidth - textWidth - padding - 1, 0)
                end
            end
        end
    end
    
    task.spawn(updateCursor)
    textBox:GetPropertyChangedSignal("Text"):Connect(updateCursor)
    textBox:GetPropertyChangedSignal("CursorPosition"):Connect(updateCursor)
    
    textBox.Focused:Connect(function()
        updateCursor()
        indicator.Size = UDim2.new(1, -2, 0, 2)
        indicator.Position = UDim2.new(0, 1, 1, 0)
        indicator.BackgroundTransparency = 0
        OverrideTag(inputFrame, { BackgroundColor3 = "InputFocused" })
        OverrideTag(indicator, { BackgroundColor3 = "Accent" })
    end)
    
    textBox.FocusLost:Connect(function(enterPressed)
        updateCursor()
        indicator.Size = UDim2.new(1, -4, 0, 1)
        indicator.Position = UDim2.new(0, 2, 1, 0)
        indicator.BackgroundTransparency = 0.5
        OverrideTag(inputFrame, { BackgroundColor3 = "Input" })
        OverrideTag(indicator, { BackgroundColor3 = "InputIndicator" })
    end)
    
    if input.Finished then
        textBox.FocusLost:Connect(function(enterPressed)
            if enterPressed then
                input:SetValue(textBox.Text)
            end
        end)
    else
        textBox:GetPropertyChangedSignal("Text"):Connect(function()
            input:SetValue(textBox.Text)
        end)
    end
    
    library.Options[elementId] = input
    
    return input
end

