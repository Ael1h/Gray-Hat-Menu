local function CreateAcrylicPaint(blurStrength)
    blurStrength = blurStrength or 0.001
    
    local vertices = { topLeft = Vector2.new(), topRight = Vector2.new(), bottomRight = Vector2.new() }
    local blurEffect = Instance.new("DepthOfFieldEffect")
    blurEffect.FarIntensity = 0
    blurEffect.InFocusRadius = 0.1
    blurEffect.NearIntensity = 1
    blurEffect.Parent = Lighting
    
    local blurPart = CreateInstance("Part", {
        Name = "Body",
        Color = Color3.new(0, 0, 0),
        Material = Enum.Material.Glass,
        Size = Vector3.new(1, 1, 0),
        Anchored = true,
        CanCollide = false,
        Locked = true,
        CastShadow = false,
        Transparency = 0.98
    }, {
        CreateInstance("SpecialMesh", { MeshType = Enum.MeshType.Brick, Offset = Vector3.new(0, 0, -1e-6) })
    })
    blurPart.Parent = Workspace
    
    local function updateVertices(frame)
        local cornerRadius = 8
        local size = frame.AbsoluteSize - Vector2.new(cornerRadius, cornerRadius)
        local position = frame.AbsolutePosition + Vector2.new(cornerRadius / 2, cornerRadius / 2)
        vertices.topLeft = position
        vertices.topRight = position + Vector2.new(size.X, 0)
        vertices.bottomRight = position + size
    end
    
    local function updateBlur()
        local camera = Workspace.CurrentCamera
        if not camera then
            return
        end
        local cameraCFrame = camera.CFrame
        local function screenToWorld(screenPoint, depth)
            local ray = camera:ScreenPointToRay(screenPoint.X, screenPoint.Y)
            return ray.Origin + ray.Direction * depth
        end
        
        local depth = 0.001
        local topLeftWorld = screenToWorld(vertices.topLeft, depth)
        local topRightWorld = screenToWorld(vertices.topRight, depth)
        local bottomRightWorld = screenToWorld(vertices.bottomRight, depth)
        
        local width = (topRightWorld - topLeftWorld).Magnitude
        local height = (bottomRightWorld - topRightWorld).Magnitude
        
        blurPart.CFrame = CFrame.fromMatrix((topLeftWorld + bottomRightWorld) / 2, cameraCFrame.XVector, cameraCFrame.YVector, cameraCFrame.ZVector)
        blurPart.Mesh.Scale = Vector3.new(width, height, 0)
    end
    
    local function setupBlur(frame)
        updateVertices(frame)
        task.spawn(updateBlur)
        
        local connections = {}
        local camera = Workspace.CurrentCamera
        if camera then
            table.insert(connections, camera:GetPropertyChangedSignal("CFrame"):Connect(updateBlur))
            table.insert(connections, camera:GetPropertyChangedSignal("ViewportSize"):Connect(updateBlur))
            table.insert(connections, camera:GetPropertyChangedSignal("FieldOfView"):Connect(updateBlur))
            task.spawn(updateBlur)
        end
        
        blurPart.Destroying:Connect(function()
            for _, connection in ipairs(connections) do
                pcall(function() connection:Disconnect() end)
            end
        end)
        
        return connections
    end
    
    local function applyBlur(frame)
        setupBlur(frame)
        return function(isVisible)
            blurPart.Transparency = isVisible and 0.98 or 1
        end
    end
    
    local acrylicFrame = CreateInstance("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 1)
    })
    
    local setVisibility = applyBlur(acrylicFrame)
    
    local acrylicPaint = {
        Frame = acrylicFrame,
        Model = blurPart,
        AddParent = function(parent)
            local connection = parent:GetPropertyChangedSignal("Visible"):Connect(function()
                setVisibility(parent.Visible)
            end)
            return connection
        end,
        SetVisibility = setVisibility
    }
    
    acrylicFrame:GetPropertyChangedSignal("AbsolutePosition"):Connect(function()
        updateVertices(acrylicFrame)
        updateBlur()
    end)
    
    acrylicFrame:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
        updateVertices(acrylicFrame)
        updateBlur()
    end)
    
    return acrylicPaint
end

