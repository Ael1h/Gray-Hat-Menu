local function GetThemeProperty(propertyName)
    local theme = Themes[FluentPro.CurrentTheme]
    if theme and theme[propertyName] ~= nil then
        return theme[propertyName]
    end
    local fallback = Themes["Dark"]
    if fallback then
        return fallback[propertyName]
    end
    return nil
end

local ThemeRegistry = {}
local TransparencyMotors = {}

local function UpdateTheme()
    for object, data in pairs(ThemeRegistry) do
        for property, themeProperty in pairs(data.Properties) do
            local value = GetThemeProperty(themeProperty)
            if value ~= nil then
                object[property] = value
            end
        end
    end
    
    for _, motor in pairs(TransparencyMotors) do
        motor:setGoal(GetThemeProperty("ElementTransparency") or 0.88)
    end
    
    local theme = Themes[FluentPro.CurrentTheme]
    if FluentPro.Window and FluentPro.Window.AcrylicPaint then
        Animation.Apply(theme, FluentPro.Window.AcrylicPaint.Frame)
        
        if theme and theme.ButtonGradient then
            getgenv().ButtonGradients = theme.ButtonGradient
        end
        
        local bgParent = FluentPro.Window.AcrylicPaint.Frame
        if bgParent then
            local bgImg = bgParent:FindFirstChild("ThemeBG")
            local bgValue = theme and theme.Background
            if bgValue and tostring(bgValue) ~= "" then
                if not bgImg then
                    bgImg = Instance.new("ImageLabel")
                    bgImg.Name = "ThemeBG"
                    bgImg.Size = UDim2.fromScale(1, 1)
                    bgImg.BackgroundTransparency = 1
                    bgImg.ScaleType = Enum.ScaleType.Crop
                    bgImg.ZIndex = 0
                    bgImg.Parent = bgParent
                end
                bgImg.Image = tostring(bgValue)
                bgImg.ImageTransparency = theme.BackgroundTransparency or 0
                bgImg.Visible = true
            elseif bgImg then
                bgImg.Visible = false
            end
        end
    end
end

local function AddThemeObject(object, properties)
    ThemeRegistry[object] = { Object = object, Properties = properties }
    UpdateTheme()
    return object
end

local function OverrideTag(object, properties)
    if ThemeRegistry[object] then
        ThemeRegistry[object].Properties = properties
        UpdateTheme()
    end
end

local function CreateInstance(className, properties, children)
    local instance = Instance.new(className)
    
    local defaults = {
        ScreenGui = { ResetOnSpawn = false, ZIndexBehavior = Enum.ZIndexBehavior.Sibling },
        Frame = { BackgroundColor3 = Color3.new(1, 1, 1), BorderColor3 = Color3.new(0, 0, 0), BorderSizePixel = 0 },
        ScrollingFrame = { BackgroundColor3 = Color3.new(1, 1, 1), BorderColor3 = Color3.new(0, 0, 0), ScrollBarImageColor3 = Color3.new(0, 0, 0) },
        TextLabel = { BackgroundColor3 = Color3.new(1, 1, 1), BorderColor3 = Color3.new(0, 0, 0), Font = Enum.Font.SourceSans, Text = "", TextColor3 = Color3.new(0, 0, 0), BackgroundTransparency = 1, TextSize = 14 },
        TextButton = { BackgroundColor3 = Color3.new(1, 1, 1), BorderColor3 = Color3.new(0, 0, 0), AutoButtonColor = false, Font = Enum.Font.SourceSans, Text = "", TextColor3 = Color3.new(0, 0, 0), TextSize = 14 },
        TextBox = { BackgroundColor3 = Color3.new(1, 1, 1), BorderColor3 = Color3.new(0, 0, 0), ClearTextOnFocus = false, Font = Enum.Font.SourceSans, Text = "", TextColor3 = Color3.new(0, 0, 0), TextSize = 14 },
        ImageLabel = { BackgroundTransparency = 1, BackgroundColor3 = Color3.new(1, 1, 1), BorderColor3 = Color3.new(0, 0, 0), BorderSizePixel = 0 },
        ImageButton = { BackgroundColor3 = Color3.new(1, 1, 1), BorderColor3 = Color3.new(0, 0, 0), AutoButtonColor = false },
        CanvasGroup = { BackgroundColor3 = Color3.new(1, 1, 1), BorderColor3 = Color3.new(0, 0, 0), BorderSizePixel = 0 }
    }
    
    if defaults[className] then
        for prop, value in pairs(defaults[className]) do
            instance[prop] = value
        end
    end
    
    if properties then
        for prop, value in pairs(properties) do
            if prop ~= "ThemeTag" then
                instance[prop] = value
            end
        end
    end
    
    if children then
        for _, child in ipairs(children) do
            child.Parent = instance
        end
    end
    
    if properties and properties.ThemeTag then
        AddThemeObject(instance, properties.ThemeTag)
    end
    
    return instance
end

local ElementContainer = {}
ElementContainer.__index = ElementContainer

function ElementContainer:SetTitle(newTitle)
    if self.TitleLabel then
        self.TitleLabel.Text = newTitle
    end
end

function ElementContainer:SetDescription(newDescription)
    if self.DescLabel then
        if newDescription == nil or newDescription == "" then
            self.DescLabel.Visible = false
        else
            self.DescLabel.Visible = true
            self.DescLabel.Text = newDescription
        end
    end
end

function ElementContainer:Destroy()
    if self.Frame then
        self.Frame:Destroy()
