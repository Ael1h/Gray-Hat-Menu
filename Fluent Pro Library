function FluentPro.InterfaceManager:ApplyFont(fontName)
    local fontPath = self.FontPaths[fontName]
    if not fontPath then
        return
    end
    
    local fontWeight = self.FontWeights[fontName] or Enum.FontWeight.Regular
    local fontStyle = self.FontStyles[fontName] or Enum.FontStyle.Normal
    local newFont = Font.new(fontPath, fontWeight, fontStyle)
    
    local gui = self.Library and self.Library.GUI
    if not gui then
        return
    end
    
    local function applyToChildren(instance, depth)
        if depth > 12 then
            return
        end
        for _, child in ipairs(instance:GetChildren()) do
            if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
                pcall(function() child.FontFace = newFont end)
            end
            applyToChildren(child, depth + 1)
        end
    end
    
    applyToChildren(gui, 0)
    self.Settings.Font = fontName
    self:SaveSettings()
end

