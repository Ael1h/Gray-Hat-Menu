function FluentPro.SaveManager:Save(configName)
    if not configName then
        return false, "No config selected"
    end
    
    local data = { objects = {} }
    
    for index, option in pairs(self.Options) do
        if self.Parser[option.Type] and not self.Ignore[index] then
            table.insert(data.objects, self.Parser[option.Type].Save(index, option))
        end
    end
    
    local success, encoded = pcall(HttpService.JSONEncode, HttpService, data)
    if not success then
        return false, "Encode failed"
    end
    
    writefile(self.Folder .. "/settings/" .. configName .. ".json", encoded)
    return true
end

function FluentPro.SaveManager:Load(configName)
    if not configName then
        return false, "No config selected"
    end
    
    local filePath = self.Folder .. "/settings/" .. configName .. ".json"
    if not isfile(filePath) then
        return false, "Invalid file"
    end
    
    local success, decoded = pcall(HttpService.JSONDecode, HttpService, readfile(filePath))
    if not success then
        return false, "Decode error"
    end
    
    for _, optionData in ipairs(decoded.objects) do
        if self.Parser[optionData.type] then
            task.spawn(function()
                self.Parser[optionData.type].Load(optionData.index, optionData)
            end)
        end
    end
    
    return true
end

function FluentPro.SaveManager:RefreshConfigList()
    local files = listfiles(self.Folder .. "/settings")
    local configs = {}
    
    for _, filePath in ipairs(files) do
        if filePath:sub(-5) == ".json" then
            local startPos = filePath:find(".json", 1, true)
            local pos = startPos
            local char = filePath:sub(pos, pos)
            while char ~= "/" and char ~= "\\" and char ~= "" do
                pos = pos - 1
                char = filePath:sub(pos, pos)
            end
            if char == "/" or char == "\\" then
                local name = filePath:sub(pos + 1, startPos - 1)
                if name ~= "options" then
                    table.insert(configs, name)
                end
            end
        end
    end
    
    return configs
end

